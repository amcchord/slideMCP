#!/bin/sh
set -eu

unset CDPATH
SCRIPT_DIR=$(cd -- "$(dirname -- "$0")" && pwd)

case "$(uname -m)" in
    x86_64|amd64)
        BINARY="$SCRIPT_DIR/slide-mcp-server-linux-amd64"
        ;;
    aarch64|arm64)
        BINARY="$SCRIPT_DIR/slide-mcp-server-linux-arm64"
        ;;
    *)
        echo "slide-mcp-server: unsupported Linux architecture: $(uname -m)" >&2
        exit 1
        ;;
esac

exec "$BINARY" "$@"
